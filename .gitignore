# ── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# ── Node ───────────────────────────────────────────────────
node_modules/
dist/
.vite/

# ── Environment files — NEVER commit real values ───────────
.env
.env.local
.env.production
.env.*.local
# .env.example files ARE committed — they document what's needed

# ── Docker volumes (local data) ────────────────────────────
prometheus-data/
grafana-data/

# ── Terraform state — contains secrets ─────────────────────
*.tfstate
*.tfstate.backup
.terraform/
*.tfvars
# terraform.tfvars.example IS committed

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
