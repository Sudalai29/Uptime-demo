# ── Backend environment variables ─────────────────────────
#
# USAGE:
#   Dev:  these are already set in docker-compose.yml — no .env needed locally
#   Prod: set in ECS task definition environment / AWS Secrets Manager
#         Sensitive values (passwords, ARNs) should go in Secrets Manager,
#         non-sensitive config can be plain ECS environment variables
#
# All variables are read in app/config.py

# ── Runtime mode ───────────────────────────────────────────
# true  = local dev (uses DynamoDB Local, logs alerts instead of SNS)
# false = AWS prod  (uses real DynamoDB, sends SNS alerts, no scheduler)
LOCAL_MODE=true

# ── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── DynamoDB ───────────────────────────────────────────────
# Dev:  points to local DynamoDB container
# Prod: leave LOCAL_DYNAMO_URL unset — boto3 uses real AWS automatically
MONITORS_TABLE=uptime-monitors
CHECKS_TABLE=uptime-checks
LOCAL_DYNAMO_URL=http://dynamodb-local:8001    # dev only — remove in prod

# ── SNS alerts ─────────────────────────────────────────────
# Prod: arn:aws:sns:<region>:<account-id>:uptime-monitor-alerts
# Dev:  leave empty — alerts are logged to console only
SNS_TOPIC_ARN=

# ── CORS ───────────────────────────────────────────────────
# Dev:  * (open — Vite proxy is the only caller)
# Prod: your actual frontend domain(s), comma-separated
ALLOWED_ORIGINS=*
# Prod example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Scheduler ──────────────────────────────────────────────
# Dev:  1 minute  (faster feedback while testing)
# Prod: 5 minutes (Lambda handles checks — this var is unused in prod)
CHECK_INTERVAL_MINUTES=1

# ── Credentials (dev only — dummy values for DynamoDB Local) ───
# Prod: IAM role on ECS task handles auth — never set real keys here
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
