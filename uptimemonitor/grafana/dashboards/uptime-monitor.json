{
  "title": "Uptime Monitor — App Dashboard",
  "uid": "uptime-app-main",
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Total Monitors",
      "description": "How many URLs are registered for monitoring",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "uptime_monitors_total", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },

    {
      "id": 2, "type": "stat", "title": "Currently UP",
      "description": "Monitors reporting healthy right now",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "uptime_monitors_up_count", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },

    {
      "id": 3, "type": "stat", "title": "Currently DOWN",
      "description": "Monitors reporting failures right now",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "uptime_monitors_down_count", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },

    {
      "id": 4, "type": "stat", "title": "Paused Monitors",
      "description": "Monitors that have been manually paused",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "uptime_monitors_paused", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },

    {
      "id": 5, "type": "stat", "title": "Checks / min",
      "description": "Rate of URL checks being performed",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(uptime_checks_total[5m])) * 60", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "decimals": 1, "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },

    {
      "id": 6, "type": "stat", "title": "Total Incidents",
      "description": "Total times a monitor has gone from UP to DOWN",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(uptime_incidents_total) or vector(0)", "legendFormat": "" }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] } } }
    },

    {
      "id": 7, "type": "timeseries", "title": "Monitor Status Over Time  (1 = UP  /  0 = DOWN)",
      "description": "Drops to 0 mean the site was unreachable during that check",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 7 },
      "targets": [{ "expr": "uptime_monitor_status", "legendFormat": "{{monitor_name}}" }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min"] } }
    },

    {
      "id": 8, "type": "timeseries", "title": "Response Time per Monitor  (ms)",
      "description": "How long each site takes to respond. Spikes = slowdowns. Gaps = outages.",
      "gridPos": { "x": 0, "y": 11, "w": 16, "h": 8 },
      "targets": [{ "expr": "rate(uptime_response_ms_sum[5m]) / rate(uptime_response_ms_count[5m])", "legendFormat": "{{monitor_name}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] } }
    },

    {
      "id": 9, "type": "timeseries", "title": "Response Time Percentiles  (all monitors combined)",
      "description": "p50=median, p90=most users, p99=worst case",
      "gridPos": { "x": 16, "y": 11, "w": 8, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(uptime_response_ms_bucket[5m])) by (le))", "legendFormat": "p50 median" },
        { "expr": "histogram_quantile(0.90, sum(rate(uptime_response_ms_bucket[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, sum(rate(uptime_response_ms_bucket[5m])) by (le))", "legendFormat": "p99 worst" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },

    {
      "id": 10, "type": "timeseries", "title": "Check Rate — UP vs DOWN",
      "description": "Green=successful checks, Red=failed checks over time",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 7 },
      "targets": [
        { "expr": "sum(rate(uptime_checks_total{status='up'}[5m]))",   "legendFormat": "✓ UP checks/s" },
        { "expr": "sum(rate(uptime_checks_total{status='down'}[5m]))", "legendFormat": "✗ DOWN checks/s" }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "✓ UP checks/s" },   "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "✗ DOWN checks/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] }
        ]
      }
    },

    {
      "id": 11, "type": "timeseries", "title": "API Request Rate by Endpoint",
      "description": "How often each API endpoint is being called",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 7 },
      "targets": [{ "expr": "sum(rate(uptime_api_requests_total[5m])) by (method, endpoint)", "legendFormat": "{{method}} {{endpoint}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 1 } } }
    },

    {
      "id": 12, "type": "timeseries", "title": "API Latency by Endpoint  (ms)",
      "description": "Response time of the Uptime Monitor API itself",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 7 },
      "targets": [{ "expr": "rate(uptime_api_latency_ms_sum[5m]) / rate(uptime_api_latency_ms_count[5m])", "legendFormat": "{{method}} {{endpoint}}" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 1, "fillOpacity": 5 } } }
    },

    {
      "id": 13, "type": "timeseries", "title": "Alerts Sent Over Time",
      "description": "DOWN alerts = new incidents. Recovery alerts = sites coming back up.",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 7 },
      "targets": [
        { "expr": "rate(uptime_alerts_total{type='down'}[5m])",     "legendFormat": "🔴 DOWN alerts" },
        { "expr": "rate(uptime_alerts_total{type='recovery'}[5m])", "legendFormat": "✅ Recovery alerts" }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "🔴 DOWN alerts" },     "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "✅ Recovery alerts" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    }

  ],
  "schemaVersion": 38,
  "version": 1
}
