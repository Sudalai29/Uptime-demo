      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-ds"
          },
          "queryMode": "Metrics",
          "namespace": "UptimeMonitor",
          "metricName": "MonitorsUp",
          "dimensions": {
            "Environment": [
              "prod"
            ]
          },
          "statistic": "Maximum",
          "period": "60",
          "refId": "A"
        }
      ]
