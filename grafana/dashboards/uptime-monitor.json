    {
      "id": 10,
      "type": "timeseries",
      "title": "API Request Count (CloudWatch Logs)",
      "description": "Total API calls per minute, parsed from structured request logs.",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-ds"
          },
          "queryMode": "Logs",
          "logGroups": [
            {
              "name": "/ecs/uptime-monitor-prod"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message like /REQUEST/ | stats count() as requests by bin(1m)",
          "refId": "A"
        }
      ]
    },
