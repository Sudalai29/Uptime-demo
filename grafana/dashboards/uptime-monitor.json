      "title": "Recent App Logs",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 6
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch-ds"
          },
          "queryMode": "Logs",
          "logGroups": [
            {
              "name": "/ecs/uptime-monitor-prod"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message not like /ELB-HealthChecker/ | sort @timestamp desc | limit 50",
          "refId": "A"
        }
      ]
